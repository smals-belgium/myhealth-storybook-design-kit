{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve",
    "lib": ["es2022", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@myhealth-belgium/component-alert": ["libs/components/alert/src/index.ts"],
      "@myhealth-belgium/design-kit": ["libs/design-kit/src/index.ts"],
      "@myhealth-storybook-design-kit/storybook": ["libs/storybook/src/index.ts"],
      "@smals-belgium/custom-ui-components": ["libs/custom-ui-components/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
